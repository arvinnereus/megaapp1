# =============================================================================
# DATABASE
# Default: SQLite (local dev). Swap for Railway PostgreSQL URL in production.
# =============================================================================
DATABASE_URL=sqlite:///app.db

# =============================================================================
# ADMIN LOGIN
# Username and password for the /admin dashboard.
# =============================================================================
ADMIN_USER=instructor
ADMIN_PASS=SaturdayWorkshop2026!

# =============================================================================
# FLASK SECRET KEY
# Used to sign session cookies. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
SECRET_KEY=change-me-in-production

# =============================================================================
# BUSINESS BRANDING
# Displayed in the UI header and emails. Change to your business name.
# =============================================================================
BUSINESS_NAME=All-in-One Business App

# =============================================================================
# FEATURE TOGGLES
# Set to "false" to hide a section from the UI and skip its blueprint.
# =============================================================================
FEATURE_PRODUCTS=true
FEATURE_CLIENTS=true
FEATURE_TASKS=true
FEATURE_EMAIL=true
FEATURE_ANALYTICS=true
FEATURE_BOOKINGS=true

# =============================================================================
# JACKIE AI ASSISTANT
# CHAT_PROVIDER: "openai" for direct OpenAI, "openrouter" for OpenRouter
# OPENAI_API_KEY: Required if CHAT_PROVIDER=openai
# OPENROUTER_API_KEY: Required if CHAT_PROVIDER=openrouter (also used for content)
# =============================================================================
OPENAI_API_KEY=
CHAT_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4o-mini

# =============================================================================
# CONTENT AUTOMATION APIs
# OPENROUTER  — AI text generation (Claude, GPT-4, etc.)
# FIRECRAWL   — Web scraping & crawling
# KIE_AI      — Nano Banana Pro image generation
# ZERNIO      — Social scheduling / publishing (formerly GetLate.dev)
# =============================================================================
OPENROUTER_API_KEY=
FIRECRAWL_API_KEY=
KIE_AI_API_KEY=
ZERNIO_API_KEY=
ZERNIO_PROFILE_ID=

# =============================================================================
# CRM INTEGRATIONS
# STRIPE_CHECKOUT_URL  — Direct link to your Stripe payment page
# LEAD_MAGNET_URL      — URL of your opt-in / lead magnet page
# =============================================================================
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_CHECKOUT_URL=https://buy.stripe.com/your-link
LEAD_MAGNET_URL=https://yoursite.com/free

# =============================================================================
# EMAIL (Resend)
# Resend is used for transactional emails (receipts, follow-ups, etc.)
# Sign up at https://resend.com — free tier is 3,000 emails/month.
# =============================================================================
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=hello@yourdomain.com

# =============================================================================
# STORAGE (Cloudflare R2)
# R2 is used for uploaded files, generated images, and exports.
# R2_PUBLIC_URL is the public domain attached to your R2 bucket.
# =============================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://assets.yourdomain.com

# =============================================================================
# UMAMI ANALYTICS (free at umami.is)
# Sign up at umami.is, create a website, copy the Website ID.
# =============================================================================
UMAMI_WEBSITE_ID=
UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
